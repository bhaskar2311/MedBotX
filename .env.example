# MedBotX Environment Configuration
# Developed by Bhaskar Shivaji Kumbhar
# Copy this file to .env and fill in your values

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.3
OPENAI_MAX_TOKENS=1000

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=MedBotX
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
SECRET_KEY=your_super_secret_key_change_in_production_32chars_min

# ── JWT Authentication ─────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database (SQLite for dev, PostgreSQL for prod) ─────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./medbotx.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/medbotx

# ── Redis (optional - for production session caching) ─────────────────────
REDIS_URL=redis://localhost:6379/0
USE_REDIS=false

# ── CORS ──────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8501

# ── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/medbotx.log

# ── Memory Settings ────────────────────────────────────────────────────────
MAX_MEMORY_MESSAGES=20
SESSION_TIMEOUT_MINUTES=30

# ── Streamlit Frontend ─────────────────────────────────────────────────────
STREAMLIT_PORT=8501
API_BASE_URL=http://localhost:8000
